# Copy this file to .env.local and fill in your actual keys
# Never commit .env.local to git

# TinyFish API key - get from agent.tinyfish.ai
TINYFISH_API_KEY=sk-tinyfish-your-key-here

# Tavily API key - get from tavily.com
TAVILY_API_KEY=tvly-your-key-here

# SerpAPI key - used for photo search in document generation
SERP_API_KEY=your-serpapi-key-here

# Ollama settings - local LLM, no key needed
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=qwen2.5:7b
